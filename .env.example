# Copy to .env and fill in — never commit .env
# Easiest path: ./scripts/onboard.sh (writes .env for you)
# Or copy a channel template: env.discord.example, env.telegram.example, etc.
# activate.sh syncs these into ~/.hermes/.env for the gateway

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
DISCORD_HOME_CHANNEL_THREAD_ID=

# LLM — Pollinations.ai (https://enter.pollinations.ai, GitHub: murderszn)
# Either spelling works; activate maps POLLENATIONS_API_KEY → POLLINATIONS_API_KEY
POLLINATIONS_API_KEY=

# Optional fallbacks
# OPENROUTER_API_KEY=